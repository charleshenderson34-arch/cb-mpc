
import subprocess
import hashlib
import os

# The 'Lock' - Hash of MQ74LG3YJD
EXPECTED_FINGERPRINT = "8d969eef6ecad3c29a3a629280e686cf0c3f5d5a86aff3ca12020c923adc6c92"

def verify_hardware():
    # Commands to pull serial number (varies by OS, e.g., system_profiler for macOS)
    serial = subprocess.check_output("system_profiler SPHardwareDataType | grep Serial", shell=True).decode()
    
    # Hash the detected serial
    actual_hash = hashlib.sha256(serial.strip().encode()).hexdigest()
    
    if actual_hash == EXPECTED_FINGERPRINT:
        return True
    return False

if verify_hardware():
    os.environ["CLAUDE_ADMIN_KEY"] = "your_actual_key_here"
    print("NOC ACCESS GRANTED: Device MQ74LG3YJD Verified.")
else:
    print("SECURITY ALERT: Hardware Mismatch. Access Denied.")
    exit(1)
