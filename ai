.exp-val{font-family:var(–mono);font-size:9px;color:var(–bright);word-break:break-all}

/* METRICS GRID */
.mgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:6px}
.mcard{background:var(–s2);border:1px solid var(–b2);border-radius:6px;padding:9px}
.mlbl{font-family:var(–mono);font-size:8px;color:var(–dim);letter-spacing:1px;text-transform:uppercase;margin-bottom:3px}
