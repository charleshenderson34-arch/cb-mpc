async function callClaude(messages, systemPrompt=null) {
const sys = systemPrompt || `You are NEXUS, an AI agent embedded in a Solana Devnet developer dashboard.

Context:

- Network: Solana Devnet (api.devnet.solana.com)
- CDP Key ID: b6b13821-0622-40d3-b5ff-bacd7b1d5d3f (CDP Solana, network: solana-devnet)
- Sentio Key: u1PBnXfqs3TCwuPlJiNHd7QhQL960EfRx
- Neynar Key: 26E0BC95-FCAE-4D05-BBB2-9902F104F4B8
- Wallet: ${walletPubkey || ‘not yet derived’}
- Active processor: processor_4.ts monitoring address 0x8215698f59f80d0ec918970674b2bfbcbc45f0a1
- Processor metrics: transaction_count, eth_value (sol_value on Solana), gas_price_gwei

You have deep knowledge of Solana development, web3, Farcaster/Neynar, Sentio analytics, and Coinbase CDP.
Be concise, precise, and developer-focused. Use technical language appropriate for a dev dashboard.
When asked about on-chain data, provide specific RPC method names and parameters.
Current slot: ${currentSlot.toLocaleString()}, TPS: ${networkTps}`;

const response = await fetch(CFG.ANTHROPIC, {
method: ‘POST’,
headers: { ‘Content-Type’: ‘application/json’ },
body: JSON.stringify({
model: CFG.CLAUDE_MODEL,
max_tokens: 1000,
system: sys,
messages: messages
})
});
if(!response.ok) {
const err = await response.json().catch(()=>({}));
throw new Error(err.error?.message || ’API error ’+response.status);
