/**

- NEXUS Backend — server.js
- Uses @solana/web3.js v1.x (npm install @solana/web3.js@1)
- Uses @anthropic-ai/sdk
  */

const express = require(‘express’);
const cors = require(‘cors’);
const dotenv = require(‘dotenv’);
const {
Connection,
Keypair,
Transaction,
TransactionInstruction,
SystemProgram,
PublicKey,
LAMPORTS_PER_SOL,
sendAndConfirmTransaction,
} = require(’@solana/web3.js’);
const Anthropic = require(’@anthropic-ai/sdk’);

// ── Bootstrap ─────────────────────────────────────────────
dotenv.config();

const app  = express();
app.use(cors());
app.use(express.json());

// ── Solana connection (@solana/web3.js Connection) ─────────
const connection = new Connection(process.env.ALCHEMY_RPC, ‘confirmed’);

// ── Wallet keypair from .env byte array ───────────────────
let walletKp;
try {
const secretBytes = new Uint8Array(JSON.parse(process.env.SOLANA_PRIVATE_KEY));
walletKp = Keypair.fromSecretKey(secretBytes);
console.log(`Wallet loaded: ${walletKp.publicKey.toBase58()}`);
} catch (e) {
console.error(‘Failed to parse SOLANA_PRIVATE_KEY:’, e.message);
process.exit(1);
}

// ── Anthropic client ──────────────────────────────────────
const anthropic = new Anthropic({ apiKey: process.env.ANTHROPIC_API_KEY });

// ── Memo program (on-chain) ───────────────────────────────
const MEMO_PROGRAM_ID = new PublicKey(‘MemoSq4gqABAXKb96qnH8TysNcWxMyWCqXgDLGmfcHr’);

// =========================================================
//  AI CHAT  —  POST /api/chat
// =========================================================
app.post(’/api/chat’, async (req, res) => {
try {
const { messages, systemPrompt } = req.body;

```
if (!Array.isArray(messages) || messages.length === 0) {
  return res.status(400).json({ error: 'messages array is required' });
}

const response = await anthropic.messages.create({
  model: 'claude-3-5-sonnet-20240620',
  max_tokens: 1000,
  system: systemPrompt || 'You are the NEXUS AI assistant, a helpful guide for Solana blockchain interactions.',
  messages,
});

res.json(response);
```

} catch (err) {
console.error(’/api/chat error:’, err.message);
res.status(500).json({ error: err.message });
}
});

// =========================================================
//  MEMO TRANSACTION  —  POST /api/solana/memo
//  Writes an arbitrary UTF-8 string to Solana via the
//  on-chain Memo program.
// =========================================================
app.post(’/api/solana/memo’, async (req, res) => {
try {
const { payload } = req.body;

```
if (!payload || typeof payload !== 'string') {
  return res.status(400).json({ error: '"payload" string is required' });
}

// Build a TransactionInstruction for the Memo program
const memoInstruction = new TransactionInstruction({
  keys: [
    {
      pubkey: walletKp.publicKey,
      isSigner: true,
      isWritable: false,
    },
  ],
  programId: MEMO_PROGRAM_ID,
  data: Buffer.from(payload, 'utf-8'),
});

const tx = new Transaction().add(memoInstruction);

// sendAndConfirmTransaction handles blockhash + confirmation
const signature = await sendAndConfirmTransaction(connection, tx, [walletKp], {
  commitment: 'confirmed',
});

console.log(`Memo tx confirmed: ${signature}`);
res.json({ signature, payload });
```

} catch (err) {
console.error(’/api/solana/memo error:’, err.message);
res.status(500).json({ error: err.message });
}
});

// =========================================================
//  SOL TRANSFER  —  POST /api/solana/transfer
//  Sends SOL from the server wallet to a given address.
// =========================================================
app.post(’/api/solana/transfer’, async (req, res) => {
try {
const { toAddress, lamports } = req.body;

```
if (!toAddress || !lamports) {
  return res.status(400).json({ error: '"toAddress" and "lamports" are required' });
}

const toPubkey = new PublicKey(toAddress);

const transferIx = SystemProgram.transfer({
  fromPubkey: walletKp.publicKey,
  toPubkey,
  lamports: Number(lamports),
});

const tx = new Transaction().add(transferIx);

const signature = await sendAndConfirmTransaction(connection, tx, [walletKp], {
  commitment: 'confirmed',
});

console.log(`Transfer tx confirmed: ${signature}`);
res.json({ signature, from: walletKp.publicKey.toBase58(), to: toAddress, lamports });
```

} catch (err) {
console.error(’/api/solana/transfer error:’, err.message);
res.status(500).json({ error: err.message });
}
});

// =========================================================
//  WALLET INFO  —  GET /api/solana/info
// =========================================================
app.get(’/api/solana/info’, async (req, res) => {
try {
const lamports = await connection.getBalance(walletKp.publicKey);
res.json({
address: walletKp.publicKey.toBase58(),
balance: lamports / LAMPORTS_PER_SOL,
lamports,
network: process.env.ALCHEMY_RPC.includes(‘devnet’) ? ‘devnet’ : ‘mainnet’,
});
} catch (err) {
console.error(’/api/solana/info error:’, err.message);
res.status(500).json({ error: err.message });
}
});

// =========================================================
//  RECENT TRANSACTIONS  —  GET /api/solana/txs
// =========================================================
app.get(’/api/solana/txs’, async (req, res) => {
try {
const limit = Math.min(Number(req.query.limit) || 5, 20);
const sigs = await connection.getSignaturesForAddress(walletKp.publicKey, { limit });
res.json({ transactions: sigs });
} catch (err) {
console.error(’/api/solana/txs error:’, err.message);
res.status(500).json({ error: err.message });
}
});

// =========================================================
//  HEALTH CHECK  —  GET /api/health
// =========================================================
app.get(’/api/health’, (_req, res) => {
res.json({ status: ‘ok’, timestamp: new Date().toISOString() });
});

// ── Start ─────────────────────────────────────────────────
const PORT = process.env.PORT || 3000;
app.listen(PORT, () => console.log(`NEXUS server running on port ${PORT}`));

