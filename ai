  feed.innerHTML = '<div class="ll" style="font-family:var(--mono);font-size:9px;padding:4px"><span class="spin"></span>Fetching Farcaster trending via Neynar (key: 26E0BC95…)</div>';
  try {
    const res = await fetch('https://api.neynar.com/v2/farcaster/feed/trending?limit=10',{
      headers:{'accept':'application/json','api_key':CFG.NEYNAR}
    });
    if(!res.ok) throw new Error('HTTP '+res.status);
    const data = await res.json();
    const casts = data.casts||[];
    document.getElementById('sCasts').textContent = casts.length;
    feed.innerHTML = '';
    casts.slice(0,8).forEach(c => {
      const div = document.createElement('div'); div.className = 'fccast';
      const author = c.author?.display_name || c.author?.username || 'anon';
      const txt = (c.text||'').slice(0,200);
      const likes = c.reactions?.likes_count||0;
      const recasts = c.reactions?.recasts_count||0;
      const when = c.timestamp ? new Date(c.timestamp).toLocaleString() : '';
      div.innerHTML = `<div class="fcauth">@${san(author)}</div><div class="fctxt">${san(txt)}</div><div class="fcmt">❤ ${san(String(likes))} &nbsp; 🔁 ${san(String(recasts))} &nbsp; ${san(when)}</div>`;
      feed.appendChild(div);
    });
    if(casts.length===0) feed.innerHTML = '<div class="ll" style="font-family:var(--mono);font-size:9px;padding:4px">No casts returned.</div>';
  } catch(e) {
    log('Neynar feed: '+e.message,'lw');
    feed.innerHTML = '';
    const info = document.createElement('div');
    info.style.cssText = 'font-family:var(--mono);font-size:9px;padding:6px 0 8px';
    info.innerHTML = `<div class="lw">⚠ ${san(e.message)} — CORS blocks direct browser → Neynar. Mock data shown:</div>`;
    feed.appendChild(info);
    [{author:'jessepollak',txt:'Base + Farcaster + Solana is the stack for the next generation of onchain social.',likes:1240,r:287},
     {author:'vitalik.eth',txt:'Account abstraction on Solana is an interesting design space worth exploring.',likes:2100,r:445},
     {author:'dwr.eth',txt:'Farcaster\'s open protocol means any chain can be home to social. Solana included.',likes:890,r:201},
    ].forEach(m=>{
      const d=document.createElement('div');d.className='fccast';
      d.innerHTML=`<div class="fcauth">@${san(m.author)} <span style="color:var(--dim);font-size:7px">[MOCK]</span></div><div class="fctxt">${san(m.txt)}</div><div class="fcmt">❤ ${m.likes} 🔁 ${m.r}</div>`;
      feed.appendChild(d);
    });
  }
}

