.wbtns{display:flex;gap:5px;margin-top:8px}
.wbtns .btn{flex:1;font-size:8px;padding:5px 4px;border-radius:4px}
.sform{background:var(–s2);border:1px solid var(–b2);border-radius:5px;padding:9px;margin-top:8px;display:none}
.sform.open{display:block}
.field{margin-bottom:6px}
.field label{display:block;font-family:var(–mono);font-size:7px;color:var(–dim);margin-bottom:2px;letter-spacing:1px;text-transform:uppercase}
.field input{width:100%;background:var(–bg);border:1px solid var(–b1);border-radius:4px;padding:5px 8px;font-family:var(–mono);font-size:10px;color:var(–bright);outline:none;transition:border-color .14s}
.field input:focus{border-color:var(–a2)}

/* FARCASTER */
.fccast{background:var(–s2);border:1px solid var(–b2);border-radius:5px;padding:8px 10px;margin-bottom:6px;animation:txi .3s ease}
.fcauth{font-family:var(–mono);font-size:9px;color:var(–a);margin-bottom:3px}
.fctxt{font-size:11px;color:var(–text);line-height:1.5}
.fcmt{font-family:var(–mono);font-size:8px;color:var(–dim);margin-top:3px}

/* LOG */
.logbox{background:var(–s2);border:1px solid var(–b2);border-radius:5px;padding:8px;max-height:200px;overflow-y:auto;font-family:var(–mono);font-size:9px;line-height:1.8}
.ll{color:var(–dim)}.lok{color:var(–a2)}.le{color:var(–red)}.li{color:var(–a3)}.lw{color:var(–gold)}.la{color:var(–a)}

/* EXPLORER */
.exp-row{display:flex;align-items:flex-start;gap:6px;padding:5px 0;border-bottom:1px solid var(–b2);font-size:11px}
.exp-row:last-child{border-bottom:none}
