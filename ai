<script>
// ═══════════════════════════════════════════════════════════
//  Config
// ═══════════════════════════════════════════════════════════
const BACKEND = 'http://localhost:3000';

// @solana/web3.js v1.x is available globally as solanaWeb3
// (loaded via unpkg IIFE bundle per npmjs.com readme)
const { Connection, PublicKey, LAMPORTS_PER_SOL } = solanaWeb3;

// Read-only client-side connection for Solana Explorer links
// (all signing happens server-side)
const EXPLORER_BASE = 'https://explorer.solana.com/tx';

let chatHistory = [];

// ═══════════════════════════════════════════════════════════
//  Utility
// ═══════════════════════════════════════════════════════════
function go(viewId, tabEl) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById(viewId).classList.add('active');
  if (tabEl) tabEl.classList.add('active');
}

function addLog(boxId, type, text) {
  const box = document.getElementById(boxId);
  if (!box) return;
  const line = document.createElement('div');
  line.className = `log-line log-${type}`;
  line.textContent = `[${new Date().toLocaleTimeString()}] ${text}`;
  box.appendChild(line);
  box.scrollTop = box.scrollHeight;
}

function addMessage(role, text) {
  const box = document.getElementById('chat-box');
  const div = document.createElement('div');
  div.className = role === 'user'     ? 'msg msg-user'
                : role === 'ai'       ? 'msg msg-ai'
                : role === 'thinking' ? 'msg msg-thinking'
                :                       'msg msg-system';
  div.textContent = role === 'thinking' ? text + ' ●●●' : text;
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
  return div;
}

function explorerLink(sig, network = 'devnet') {
  return `${EXPLORER_BASE}/${sig}?cluster=${network}`;
}

// ═══════════════════════════════════════════════════════════
//  Wallet info
// ═══════════════════════════════════════════════════════════
async function refreshAll() {
  addLog('wallet-log', 'info', '» Fetching wallet info from backend…');
  try {
    const res  = await fetch(`${BACKEND}/api/solana/info`);
    const data = await res.json();

    if (data.error) throw new Error(data.error);

    document.getElementById('wBal').textContent  = data.balance.toFixed(6) + ' SOL';
    document.getElementById('wAddr').textContent = data.address;
    document.getElementById('wNet').textContent  = data.network.toUpperCase();
    document.getElementById('net-label').textContent = data.network;

    addLog('wallet-log', 'ok',   `» Balance: ${data.balance.toFixed(6)} SOL`);
    addLog('wallet-log', 'ok',   `» Address: ${data.address}`);
    addLog('wallet-log', 'info', `» Network: ${data.network}`);
  } catch (e) {
    addLog('wallet-log', 'err', '» ' + e.message);
  }
}

// ═══════════════════════════════════════════════════════════
//  AI Chat
// ═══════════════════════════════════════════════════════════
async function sendChat() {
  const input = document.getElementById('chat-input');
  const prompt = input.value.trim();
  if (!prompt) return;
  input.value = '';

  addMessage('user', prompt);
  const thinking = addMessage('thinking', 'Thinking');

  try {
    const res = await fetch(`${BACKEND}/api/chat`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        messages: [...chatHistory, { role: 'user', content: prompt }],
        systemPrompt:
          'You are the NEXUS AI, an expert Solana blockchain assistant. ' +
          'You help users understand transactions, wallets, smart contracts, and the @solana/web3.js library. ' +
          'Be concise, technically precise, and use monospace-friendly formatting when sharing code.'
      })
    });
    const data = await res.json();
    thinking.remove();

    if (data.error) throw new Error(data.error);

    const text = data.content[0].text;
    addMessage('ai', text);

    chatHistory.push({ role: 'user',      content: prompt });
    chatHistory.push({ role: 'assistant', content: text   });
  } catch (e) {
    thinking.remove();
    addMessage('system', 'Error: ' + e.message);
  }
}

// ═══════════════════════════════════════════════════════════
//  Memo TX
// ═══════════════════════════════════════════════════════════
async function sendMemo() {
  const payload = document.getElementById('memo-input').value.trim();
  if (!payload) { addLog('memo-log', 'warn', '» Memo cannot be empty'); return; }

  addLog('memo-log', 'info', `» Sending memo: "${payload.slice(0, 40)}…"`);
  try {
    const res  = await fetch(`${BACKEND}/api/solana/memo`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ payload })
    });
    const data = await res.json();
    if (data.error) throw new Error(data.error);

    addLog('memo-log', 'ok',   `» Confirmed! Sig: ${data.signature.slice(0, 28)}…`);
    addLog('memo-log', 'info', `» Explorer: ${explorerLink(data.signature)}`);
    addLog('wallet-log', 'ok', `» Memo TX: ${data.signature.slice(0, 20)}…`);
  } catch (e) {
    addLog('memo-log', 'err', '» ' + e.message);
  }
}

async function fillMemo() {
  addLog('memo-log', 'info', '» Asking AI to generate a memo…');
  try {
    const res = await fetch(`${BACKEND}/api/chat`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        messages: [{ role: 'user', content: 'Generate a short (under 50 chars) Solana memo string for a status ping. Return ONLY the memo string, no quotes or explanation.' }],
        systemPrompt: 'You output only raw Solana memo strings. No explanation, no quotes.'
      })
    });
    const data = await res.json();
    if (data.error) throw new Error(data.error);
    const memo = data.content[0].text.trim().slice(0, 50);
    document.getElementById('memo-input').value = memo;
    addLog('memo-log', 'ok', `» AI suggested: "${memo}"`);
  } catch (e) {
    addLog('memo-log', 'err', '» ' + e.message);
  }
}

// ═══════════════════════════════════════════════════════════
//  SOL Transfer
// ═══════════════════════════════════════════════════════════
async function sendSOL() {
  const toAddress = document.getElementById('send-addr').value.trim();
  const solAmt    = parseFloat(document.getElementById('send-amt').value);

  if (!toAddress) { addLog('send-log', 'warn', '» Address is required'); return; }
  if (isNaN(solAmt) || solAmt <= 0) { addLog('send-log', 'warn', '» Invalid amount'); return; }

  // Validate address client-side using @solana/web3.js PublicKey
  try {
    new PublicKey(toAddress);
  } catch {
    addLog('send-log', 'err', '» Invalid Solana public key');
    return;
  }

  const lamports = Math.round(solAmt * LAMPORTS_PER_SOL);
  addLog('send-log', 'info', `» Sending ${solAmt} SOL (${lamports} lamports) to ${toAddress.slice(0,12)}…`);

  try {
    const res = await fetch(`${BACKEND}/api/solana/transfer`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ toAddress, lamports })
    });
    const data = await res.json();
    if (data.error) throw new Error(data.error);

    addLog('send-log', 'ok',   `» Transfer confirmed! Sig: ${data.signature.slice(0, 28)}…`);
    addLog('send-log', 'info', `» Explorer: ${explorerLink(data.signature)}`);
    refreshAll();
  } catch (e) {
    addLog('send-log', 'err', '» ' + e.message);
  }
}

// ═══════════════════════════════════════════════════════════
//  TX History
// ═══════════════════════════════════════════════════════════
async function loadHistory() {
  const limit  = document.getElementById('tx-limit').value;
  const txList = document.getElementById('tx-list');
  txList.innerHTML = '<div style="color:var(--sol3);font-size:11px">» Loading…</div>';

  try {
    const res  = await fetch(`${BACKEND}/api/solana/txs?limit=${limit}`);
    const data = await res.json();
    if (data.error) throw new Error(data.error);

    if (!data.transactions.length) {
      txList.innerHTML = '<div style="color:var(--muted);font-size:11px">No transactions found.</div>';
      return;
    }

    txList.innerHTML = '';
    data.transactions.forEach(tx => {
      const div = document.createElement('div');
      div.className = 'tx-item';

      const statusClass = tx.err ? 'tx-fail' : 'tx-ok';
      const statusText  = tx.err ? 'FAILED'  : 'OK';
      const slotTime    = tx.blockTime
        ? new Date(tx.blockTime * 1000).toLocaleString()
        : 'unknown time';

      div.innerHTML = `
        <div class="tx-sig">${tx.signature}</div>
        <div class="tx-meta">
          <span class="${statusClass}">[${statusText}]</span>
          &nbsp;Slot ${tx.slot} &nbsp;·&nbsp; ${slotTime}
          &nbsp;·&nbsp;
          <a href="${explorerLink(tx.signature)}" target="_blank"
             style="color:var(--sol3);text-decoration:none">Explorer ↗</a>
        </div>`;
      txList.appendChild(div);
    });
  } catch (e) {
    txList.innerHTML = `<div style="color:var(--err);font-size:11px">Error: ${e.message}</div>`;
  }
}

