main{display:grid;grid-template-columns:195px 1fr 270px;overflow:hidden;height:calc(100vh - 58px)}

/* SIDEBAR */
aside{background:rgba(5,10,14,.9);border-right:1px solid var(–b1);padding:12px 0;overflow-y:auto;display:flex;flex-direction:column}
.ss{padding:10px 14px 4px;font-family:var(–mono);font-size:8px;letter-spacing:2px;color:var(–dim);text-transform:uppercase}
.nav{display:flex;align-items:center;gap:8px;padding:8px 16px;cursor:pointer;font-size:12px;color:var(–dim);border-left:2px solid transparent;transition:all .14s;user-select:none}
.nav:hover{color:var(–text);background:rgba(153,69,255,.04);border-left-color:rgba(153,69,255,.2)}
.nav.active{color:var(–a);background:rgba(153,69,255,.08);border-left-color:var(–a)}
.nic{font-size:12px;width:14px;text-align:center}
.ntg{margin-left:auto;font-family:var(–mono);font-size:7px;padding:1px 5px;border-radius:3px}
.ti{background:rgba(77,106,122,.12);color:var(–dim);border:1px solid rgba(77,106,122,.2)}
.tl{background:rgba(153,69,255,.1);color:var(–a);border:1px solid rgba(153,69,255,.2)}
.tok{background:rgba(20,241,149,.1);color:var(–a2);border:1px solid rgba(20,241,149,.2)}
.ter{background:rgba(255,59,92,.1);color:var(–red);border:1px solid rgba(255,59,92,.2)}
.sdiv{height:1px;background:var(–b1);margin:8px 12px}

/* CENTER */
.center{overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:12px}
.view{display:none;flex-direction:column;gap:12px}
.view.active{display:flex}

/* ALERT */
.al{border-radius:6px;padding:8px 12px;display:flex;align-items:center;gap:8px;font-family:var(–mono);font-size:10px;flex-shrink:0}
.ali{background:rgba(153,69,255,.06);border:1px solid rgba(153,69,255,.2);color:var(–a)}
.alok{background:rgba(20,241,149,.06);border:1px solid rgba(20,241,149,.2);color:var(–a2)}
.alw{background:rgba(255,209,102,.06);border:1px solid rgba(255,209,102,.2);color:var(–gold)}
.ale{background:rgba(255,59,92,.06);border:1px solid rgba(255,59,92,.2);color:var(–red)}

/* STAT CARDS */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;flex-shrink:0}
.sc{background:var(–s1);border:1px solid var(–b1);border-radius:8px;padding:12px;position:relative;overflow:hidden}
.sc::before{content:’’;position:absolute;top:0;left:0;right:0;height:2px;background:var(–ca,var(–a));box-shadow:0 0 8px var(–ca,var(–a))}
.slb{font-family:var(–mono);font-size:8px;letter-spacing:1.5px;color:var(–dim);text-transform:uppercase;margin-bottom:4px}
.sv{font-family:var(–dsp);font-size:21px;letter-spacing:1px;color:var(–bright);line-height:1}
.ss2{font-family:var(–mono);font-size:8px;margin-top:3px}
.up{color:var(–a2)}.dn{color:var(–red)}.neu{color:var(–dim)}

/* PANEL */
.panel{background:var(–s1);border:1px solid var(–b1);border-radius:8px;padding:14px;flex-shrink:0}
.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.pt{font-family:var(–dsp);font-size:16px;letter-spacing:1px;color:var(–bright)}
.ps{font-family:var(–mono);font-size:8px;color:var(–dim);letter-spacing:1px}
.tabs{display:flex;gap:4px}
.tab{font-family:var(–mono);font-size:8px;padding:3px 8px;border-radius:3px;border:1px solid var(–b1);background:transparent;color:var(–dim);cursor:pointer;transition:all .14s}
.tab.active,.tab:hover{border-color:var(–a);color:var(–a);background:rgba(153,69,255,.06)}

/* CHART */
.cw{position:relative;height:130px}
.csvg{width:100%;height:100%}
.c-area{fill:url(#cg)}
.c-line{fill:none;stroke:var(–a2);stroke-width:2;stroke-linejoin:round}
.c-dot{fill:var(–a2);filter:drop-shadow(0 0 4px var(–a2))}
.ctip{position:absolute;background:var(–s2);border:1px solid var(–b1);border-radius:4px;padding:4px 8px;font-family:var(–mono);font-size:10px;color:var(–text);pointer-events:none;display:none;z-index:10;white-space:nowrap}

/* COIN GRID */
.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;flex-shrink:0}
.ccard{background:var(–s1);border:1px solid var(–b1);border-radius:7px;padding:10px 12px;display:flex;align-items:center;gap:8px;cursor:pointer;transition:all .14s}
.ccard:hover{border-color:rgba(153,69,255,.3);transform:translateY(-1px);box-shadow:0 4px 16px rgba(0,0,0,.3)}
.cav{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;font-family:var(–mono);flex-shrink:0}
.ci{flex:1;min-width:0}
.cn{font-size:11px;font-weight:500;color:var(–bright)}
.csy{font-family:var(–mono);font-size:8px;color:var(–dim)}
.cr2{text-align:right}
.cp{font-family:var(–mono);font-size:11px;color:var(–bright)}
.cc{font-family:var(–mono);font-size:8px}

/* NET GRAPH */
.nsvg{width:100%;height:180px}
.nlink{stroke:var(–a);stroke-opacity:.15;stroke-width:1}

/* AI CHAT */
.ai-wrap{display:flex;flex-direction:column;gap:8px;height:100%}
.ai-msgs{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:8px;padding-bottom:4px}
.msg{border-radius:6px;padding:9px 11px;font-size:12px;line-height:1.55;animation:msgin .25s ease}
@keyframes msgin{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
.msg-u{background:rgba(153,69,255,.1);border:1px solid rgba(153,69,255,.2);color:var(–bright);align-self:flex-end;max-width:85%}
.msg-a{background:var(–s2);border:1px solid var(–b2);color:var(–text);align-self:flex-start;max-width:95%}
.msg-author{font-family:var(–mono);font-size:8px;margin-bottom:4px}
.msg-u .msg-author{color:var(–a);text-align:right}
.msg-a .msg-author{color:var(–a2)}
.ai-input-row{display:flex;gap:6px;flex-shrink:0}
.ai-input{flex:1;background:var(–bg);border:1px solid var(–b1);border-radius:5px;padding:7px 10px;font-family:var(–mono);font-size:10px;color:var(–bright);outline:none;transition:border-color .14s}
.ai-input:focus{border-color:var(–a)}
.ai-send{background:var(–a);color:#fff;border:none;border-radius:5px;padding:7px 12px;font-family:var(–mono);font-size:10px;font-weight:700;cursor:pointer;transition:all .2s;white-space:nowrap}
.ai-send:hover{background:#b060ff}
.ai-send:disabled{opacity:.4;cursor:not-allowed}

/* RIGHT PANEL */
.right{background:rgba(5,10,14,.9);border-left:1px solid var(–b1);overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:11px}
.rt{font-family:var(–mono);font-size:8px;letter-spacing:2px;color:var(–dim);text-transform:uppercase;margin-bottom:6px}
.card{background:var(–s1);border:1px solid var(–b1);border-radius:7px;padding:12px}

/* STATUS */
.si{display:flex;align-items:center;gap:7px;padding:5px 0;border-bottom:1px solid var(–b2)}
.si:last-child{border-bottom:none}
.dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.dok{background:var(–a2);box-shadow:0 0 5px var(–a2)}
.dw{background:var(–gold);box-shadow:0 0 5px var(–gold)}
.derr{background:var(–red);box-shadow:0 0 5px var(–red)}
.di{background:var(–dim)}
.slbl{font-size:10px;color:var(–text);flex:1}
.sval{font-family:var(–mono);font-size:8px;color:var(–dim)}

/* GAS / TPS */
.grow{display:flex;justify-content:space-between;align-items:center;padding:3px 0}
.glbl{font-size:10px;color:var(–dim)}
.gval{font-family:var(–mono);font-size:10px}
.gbar{height:3px;background:var(–b1);border-radius:2px;margin:2px 0 4px}
.gfill{height:100%;border-radius:2px;transition:width .5s ease}

/* TX FEED */
.txi{background:var(–s2);border:1px solid var(–b2);border-radius:5px;padding:7px 9px;margin-bottom:5px;animation:txi .3s ease}
@keyframes txi{from{opacity:0;transform:translateX(6px)}to{opacity:1;transform:none}}
.txtp{display:flex;justify-content:space-between;align-items:center;margin-bottom:2px}
.txty{font-family:var(–mono);font-size:7px;letter-spacing:.8px;padding:2px 5px;border-radius:2px}
.tt-s{background:rgba(255,59,92,.1);color:var(–red);border:1px solid rgba(255,59,92,.2)}
.tt-r{background:rgba(20,241,149,.07);color:var(–a2);border:1px solid rgba(20,241,149,.18)}
.tt-p{background:rgba(153,69,255,.08);color:var(–a);border:1px solid rgba(153,69,255,.18)}
.txamt{font-family:var(–mono);font-size:10px;color:var(–bright)}
.txm{display:flex;justify-content:space-between}
.txh,.txti{font-family:var(–mono);font-size:8px;color:var(–dim)}

/* WALLET */
.waddr{font-family:var(–mono);font-size:9px;color:var(–a2);word-break:break-all;cursor:pointer;margin-bottom:6px}
.waddr:hover{text-decoration:underline}
.wbal{font-family:var(–dsp);font-size:26px;color:var(–bright);line-height:1}
