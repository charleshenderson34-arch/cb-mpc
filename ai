  <!-- @solana/web3.js v1.x IIFE bundle (CDN) per npmjs.com readme -->

  <script src="https://unpkg.com/@solana/web3.js@1/lib/index.iife.min.js"></script>

  <style>
    /* ── Design tokens ─────────────────────────────────── */
    :root {
      --sol:    #9945FF;
      --sol2:   #14F195;
      --sol3:   #00C2FF;
      --warn:   #FFB800;
      --err:    #FF4D4D;
      --bg:     #04050a;
      --bg2:    #080c17;
      --panel:  rgba(13, 18, 33, 0.96);
      --border: rgba(153, 69, 255, 0.22);
      --border2:rgba(20, 241, 149, 0.22);
      --text:   #e2e8f8;
      --muted:  #5a6890;
      --font:   'Courier New', 'Consolas', monospace;
      --head:   'Georgia', serif;
    }

    /* ── Reset & base ──────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-size: 13px;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── Animated grid background ──────────────────────── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(153,69,255,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(153,69,255,0.04) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    /* ── Layout ────────────────────────────────────────── */
    #app { position: relative; z-index: 1; max-width: 1400px; margin: 0 auto; padding: 16px; }

    /* ── Header ────────────────────────────────────────── */
    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 20px;
      border: 1px solid var(--border);
      background: var(--panel);
      margin-bottom: 16px;
      backdrop-filter: blur(10px);
    }

    .logo {
      font-family: var(--head);
      font-size: 22px;
      letter-spacing: 6px;
      background: linear-gradient(90deg, var(--sol), var(--sol2), var(--sol3));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-transform: uppercase;
    }

    .status-bar {
      display: flex;
      align-items: center;
      gap: 20px;
      font-size: 11px;
      color: var(--muted);
    }

    .dot {
      display: inline-block;
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--sol2);
      box-shadow: 0 0 8px var(--sol2);
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.3; }
    }

    /* ── Tabs ──────────────────────────────────────────── */
    .tabs {
      display: flex;
      gap: 2px;
      margin-bottom: 16px;
      border-bottom: 1px solid var(--border);
    }

    .tab {
      padding: 8px 20px;
      cursor: pointer;
      color: var(--muted);
      font-family: var(--font);
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      border: none;
      background: transparent;
      transition: color 0.2s, border-bottom 0.2s;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
    }

    .tab:hover { color: var(--text); }

    .tab.active {
      color: var(--sol2);
      border-bottom: 2px solid var(--sol2);
    }

    /* ── Views ─────────────────────────────────────────── */
    .view { display: none; }
    .view.active { display: grid; gap: 16px; }

    /* ── Panel cards ───────────────────────────────────── */
    .card {
      background: var(--panel);
      border: 1px solid var(--border);
      padding: 20px;
      backdrop-filter: blur(8px);
    }

    .card-title {
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--sol);
      margin-bottom: 16px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }

    /* ── Wallet stats ──────────────────────────────────── */
    #v-wallet { grid-template-columns: 1fr 1fr; grid-template-rows: auto auto auto; }

    .stat-block {
      background: rgba(153,69,255,0.06);
      border: 1px solid var(--border);
      padding: 16px;
    }

    .stat-label {
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .stat-value {
      font-size: 24px;
      color: var(--sol2);
      font-family: var(--head);
    }

    .stat-sub {
      font-size: 10px;
      color: var(--muted);
      margin-top: 4px;
      word-break: break-all;
    }

    .full-col { grid-column: 1 / -1; }

    /* ── Inputs & buttons ──────────────────────────────── */
    input, textarea {
      background: rgba(0,0,0,0.4);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: var(--font);
      font-size: 12px;
      padding: 10px 14px;
      width: 100%;
      outline: none;
      transition: border-color 0.2s;
    }

    input:focus, textarea:focus {
      border-color: var(--sol);
    }

    textarea { resize: vertical; min-height: 80px; }

    .btn {
      padding: 10px 24px;
      font-family: var(--font);
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      border: none;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.1s;
    }

    .btn:active { transform: scale(0.97); }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; }

    .btn-primary {
      background: linear-gradient(90deg, var(--sol), #7733cc);
      color: #fff;
    }

    .btn-green {
      background: linear-gradient(90deg, #0da86a, var(--sol2));
      color: #000;
    }

    .btn-outline {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--muted);
    }

    .btn-outline:hover { border-color: var(--sol2); color: var(--sol2); }

    .row { display: flex; gap: 10px; align-items: flex-end; }
    .row input { flex: 1; }

    /* ── Log output ────────────────────────────────────── */
    .log-box {
      background: rgba(0,0,0,0.6);
      border: 1px solid var(--border);
      min-height: 120px;
      max-height: 220px;
      overflow-y: auto;
      padding: 10px;
      font-size: 11px;
      font-family: var(--font);
    }

    .log-line { margin-bottom: 4px; }
    .log-ok   { color: var(--sol2); }
    .log-err  { color: var(--err); }
    .log-info { color: var(--sol3); }
    .log-warn { color: var(--warn); }
    .log-sys  { color: var(--muted); }

    /* ── AI Chat ───────────────────────────────────────── */
    #v-ai { grid-template-columns: 1fr; grid-template-rows: 1fr auto; }

    .chat-box {
      background: rgba(0,0,0,0.5);
      border: 1px solid var(--border);
      height: 460px;
      overflow-y: auto;
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      scroll-behavior: smooth;
    }

    .msg {
      max-width: 82%;
      padding: 12px 16px;
      line-height: 1.6;
      font-size: 12px;
      animation: fadeIn 0.25s ease;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; } }

    .msg-user {
      background: rgba(153,69,255,0.15);
      border: 1px solid var(--border);
      align-self: flex-end;
      color: var(--text);
    }

    .msg-ai {
      background: rgba(20,241,149,0.07);
      border: 1px solid var(--border2);
      align-self: flex-start;
      color: var(--sol2);
    }

    .msg-system {
      background: rgba(255,77,77,0.1);
      border: 1px solid rgba(255,77,77,0.3);
      align-self: center;
      color: var(--err);
      font-size: 11px;
      max-width: 100%;
    }

    .msg-thinking {
      align-self: flex-start;
      color: var(--muted);
      font-size: 11px;
      animation: blink 1.2s step-start infinite;
    }

    @keyframes blink { 50% { opacity: 0.2; } }

    .chat-input-row {
      display: flex;
      gap: 10px;
      margin-top: 12px;
    }

    .chat-input-row textarea { min-height: 48px; flex: 1; }

    /* ── TX History ────────────────────────────────────── */
    .tx-item {
      border-bottom: 1px solid var(--border);
      padding: 10px 0;
      font-size: 11px;
    }

    .tx-sig  { color: var(--sol3); word-break: break-all; }
    .tx-meta { color: var(--muted); font-size: 10px; margin-top: 3px; }
    .tx-ok   { color: var(--sol2); }
    .tx-fail { color: var(--err); }

    /* ── Scrollbar ─────────────────────────────────────── */
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--sol); border-radius: 2px; }

    /* ── Responsive ────────────────────────────────────── */
    @media (max-width: 700px) {
      #v-wallet { grid-template-columns: 1fr; }
      .row { flex-direction: column; }
    }
  </style>

</head>
