        <tr><td>Circulating Supply</td><td id="n-circ">—</td></tr>
        <tr><td>Avg TPS (1min)</td><td class="b" id="n-tps">—</td></tr>
      </table>
    </div>
  </div>

  <div class="g3">
    <div class="panel">
      <div class="ph"><span class="pt">EPOCH PROGRESS</span><span class="pb b">SLOT INFO</span></div>
      <div class="val-box blue mb8" id="n-epoch-detail">Loading epoch info...</div>
      <div class="ebar"><div class="efill" id="n-epoch-fill" style="width:0%"></div></div>
    </div>
    <div class="panel blue">
      <div class="ph"><span class="pt">SUPPLY INFO</span><span class="pb b">LAMPORTS</span></div>
      <div class="val-box" id="n-supply-detail">Loading supply data...</div>
    </div>
    <div class="panel purple">
      <div class="ph"><span class="pt">EVM CHAIN REGISTRY</span><span class="pb p">CONTRACTS</span></div>
      <table class="ct">
        <tr><th>CHAIN</th><th>CONTRACT</th><th>TYPE</th></tr>
        <tr><td class="g">Optimism (10)</td><td class="mono" style="font-size:8px">0x31724...c9a5</td><td class="p">StakedTokenV1</td></tr>
        <tr><td class="g">Optimism (10)</td><td class="mono" style="font-size:8px">0xbe989...704</td><td style="color:var(--gold)">FiatTokenProxy</td></tr>
        <tr><td class="b">Optimism (10)</td><td class="mono" style="font-size:8px">0x2260f...599</td><td class="g">WBTC · Sentio</td></tr>
      </table>
    </div>
  </div>
</div>

<script>
// ── RPC ENDPOINTS ──
const SOL_RPC = 'https://api.devnet.solana.com';
const OP_RPC  = 'https://mainnet.optimism.io';

// ── STATE ──
let live = false, intervals = [], tpsHistory = [], lastSlot = null, lastSlotTime = null;

// ── PAGE NAV ──
function showPage(id, el) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  el.classList.add('active');
}

// ── SOLANA RPC ──
async function sol(method, params=[]) {
  const r = await fetch(SOL_RPC,{
    method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({jsonrpc:'2.0',id:1,method,params})
  });
  return (await r.json()).result;
}

// ── EVM RPC ──
async function evm(rpc, method, params=[]) {
  const r = await fetch(rpc,{
    method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({jsonrpc:'2.0',id:1,method,params})
  });
  return (await r.json()).result;
}

// ── CONSOLE ──
function log(msg,type='') {
  const c=document.getElementById('console');
  if(!c) return;
  const d=document.createElement('div');
  d.className='ll '+type; d.textContent=msg;
  c.appendChild(d); c.scrollTop=c.scrollHeight;
}
function clearConsole() {
  const c=document.getElementById('console');
  if(c){c.innerHTML='';log('Console cleared','i');}
}

// ── SLOT + TPS ──
async function fetchSlot() {
  try {
    const slot = await sol('getSlot');
    const now = Date.now();
    document.getElementById('s-slot').textContent = slot.toLocaleString();
    document.getElementById('t-slot').textContent = slot.toLocaleString();
    if(document.getElementById('w-slot')) document.getElementById('w-slot').textContent = slot.toLocaleString();
    if(document.getElementById('n-slot')) document.getElementById('n-slot').textContent = slot.toLocaleString();

    const perf = await sol('getRecentPerformanceSamples',[5]);
    if(perf && perf.length) {
      const tps = Math.round(perf[0].numTransactions / perf[0].samplePeriodSecs);
      document.getElementById('s-tps').textContent = tps;
      document.getElementById('t-tps').textContent = tps;
      if(document.getElementById('n-tps')) document.getElementById('n-tps').textContent = tps;
      tpsHistory.push(tps);
      if(tpsHistory.length>60) tpsHistory.shift();
      drawTPS();
    }

    // block feed
    const bf = document.getElementById('blockFeed');
    const item = document.createElement('div');
    item.className='block-row';
    const txc = Math.floor(Math.random()*800+100);
    item.innerHTML=`<span class="bslot">#${slot.toLocaleString()}</span><span>${txc} txs</span><span style="color:var(--dim);font-size:9px">${new Date().toLocaleTimeString()}</span>`;
    if(bf.firstChild && bf.firstChild.textContent.includes('No blocks')) bf.innerHTML='';
    bf.insertBefore(item,bf.firstChild);
    if(bf.children.length>8) bf.removeChild(bf.lastChild);

    lastSlot=slot; lastSlotTime=now;
  } catch(e){ log('Slot error: '+e.message,'e'); }
}

async function fetchTx() {
  try {
    const sigs = await sol('getSignaturesForAddress',['Vote111111111111111111111111111111111111111p',{limit:6}]);
    if(!sigs||!sigs.length) return;
    const feed=document.getElementById('txFeed');
    feed.innerHTML='';
    sigs.forEach(s=>{
      const d=document.createElement('div');
      d.className='tx-item';
      const ok=!s.err;
      d.innerHTML=`<div class="tx-sig" onclick="window.open('https://explorer.solana.com/tx/${s.signature}?cluster=devnet','_blank')">${s.signature.slice(0,10)}...${s.signature.slice(-8)}</div>
      <div class="tx-meta"><span>Slot ${s.slot?.toLocaleString()||'—'}</span><span class="${ok?'ok':'fail'}">${ok?'✓ OK':'✗ FAIL'}</span></div>`;
      feed.appendChild(d);
    });
  } catch(e){}
}

async function fetchEpoch() {
  try {
    const info = await sol('getEpochInfo');
    if(!info) return;
    const pct = Math.round(info.slotIndex/info.slotsInEpoch*100);
    document.getElementById('s-epoch').textContent = info.epoch;
    document.getElementById('t-epoch').textContent  = info.epoch;
    document.getElementById('s-epoch-sub').textContent = `${info.slotIndex}/${info.slotsInEpoch}`;
    if(document.getElementById('w-epoch-info'))
      document.getElementById('w-epoch-info').textContent = `Epoch ${info.epoch} · ${pct}% · ${(info.slotsInEpoch-info.slotIndex).toLocaleString()} slots remain`;
    const ef=document.getElementById('epoch-fill'); if(ef) ef.style.width=pct+'%';
    if(document.getElementById('n-epoch')) {
      document.getElementById('n-epoch').textContent = info.epoch;
      document.getElementById('n-slots-epoch').textContent = info.slotsInEpoch.toLocaleString();
      document.getElementById('n-slot-idx').textContent = info.slotIndex.toLocaleString();
      document.getElementById('n-epoch-detail').textContent = `Epoch ${info.epoch} · ${pct}% complete · ${(info.slotsInEpoch-info.slotIndex).toLocaleString()} slots remaining`;
      const nf=document.getElementById('n-epoch-fill'); if(nf) nf.style.width=pct+'%';
    }
  } catch(e){}
}

async function fetchSupply() {
  try {
    const s = await sol('getSupply');
    if(!s) return;
    const total=(s.value.total/1e9).toFixed(0);
    const circ=(s.value.circulating/1e9).toFixed(0);
    const txt=`Total: ${Number(total).toLocaleString()} SOL · Circ: ${Number(circ).toLocaleString()} SOL`;
    if(document.getElementById('w-supply')) document.getElementById('w-supply').textContent=txt;
    if(document.getElementById('n-supply')) document.getElementById('n-supply').textContent=Number(total).toLocaleString()+' SOL';
    if(document.getElementById('n-circ'))   document.getElementById('n-circ').textContent=Number(circ).toLocaleString()+' SOL';
    if(document.getElementById('n-supply-detail')) document.getElementById('n-supply-detail').textContent=txt;
  } catch(e){}
}

async function fetchVersion() {
  try {
    const v = await sol('getVersion');
    if(!v) return;
    const vt=`solana-core ${v['solana-core']}`;
    if(document.getElementById('w-version')) document.getElementById('w-version').textContent=vt+` · feature-set ${v['feature-set']}`;
    if(document.getElementById('n-version')) document.getElementById('n-version').textContent=vt;
  } catch(e){}
}

async function fetchValidators() {
  try {
    const v = await sol('getVoteAccounts');
    if(!v) return;
    const cur=v.current.length, del=v.delinquent.length;
    document.getElementById('s-validators').textContent=cur+del;
    if(document.getElementById('n-validators')) document.getElementById('n-validators').textContent=cur;
    if(document.getElementById('n-delinquent')) document.getElementById('n-delinquent').textContent=del;
    drawNetMap(cur,del);
  } catch(e){}
}

async function fetchTxCount() {
  try {
    const c = await sol('getTransactionCount');
    if(c && document.getElementById('w-txcount'))
      document.getElementById('w-txcount').textContent = Number(c).toLocaleString() + ' txs';
  } catch(e){}
}

// ── WALLET ACTIONS ──
async function checkSolBalance() {
  const addr=document.getElementById('w-lookup').value.trim();
  if(!addr){log('Enter an address','w');return;}
  log(`Checking SOL balance: ${addr.slice(0,8)}...`,'i');
  try {
    const r=await sol('getBalance',[addr]);
    const sol_amt=(r.value/1e9).toFixed(6);
    document.getElementById('w-address').textContent=addr;
    document.getElementById('w-balance').textContent=sol_amt+' SOL';
    log(`Balance: ${sol_amt} SOL`,'s');
  } catch(e){ log('Balance check failed: '+e.message,'e'); }
}

async function reqAirdrop() {
  const addr=document.getElementById('w-address').textContent;
  if(addr==='—'){log('Enter & check a wallet first','w');return;}
  log(`Requesting 1 SOL airdrop → ${addr.slice(0,8)}...`,'i');
  try {
    const sig=await sol('requestAirdrop',[addr,1000000000]);
    log(`Airdrop tx: ${sig.slice(0,16)}...`,'s');
  } catch(e){ log('Airdrop failed: '+e.message,'e'); }
}

async function checkEvmBalance() {
  const addr=document.getElementById('evm-addr').value.trim();
  if(!addr) return;
  try {
    const hex=await evm('https://cloudflare-eth.com','eth_getBalance',[addr,'latest']);
    const eth=(parseInt(hex,16)/1e18).toFixed(6);
    document.getElementById('evm-balance').textContent=eth+' ETH';
    log(`ETH balance ${addr.slice(0,8)}...: ${eth} ETH`,'s');
  } catch(e){ log('EVM balance failed: '+e.message,'e'); }
}

async function checkOpBalance() {
  const addr=document.getElementById('evm-addr').value.trim();
  if(!addr) return;
  try {
    const hex=await evm(OP_RPC,'eth_getBalance',[addr,'latest']);
    const eth=(parseInt(hex,16)/1e18).toFixed(6);
    document.getElementById('evm-balance').textContent=eth+' ETH (Optimism)';
    log(`OP balance ${addr.slice(0,8)}...: ${eth} ETH`,'s');
  } catch(e){ log('OP balance failed: '+e.message,'e'); }
}

// ── CONTRACT STATE ──
async function fetchContractState() {
  const addr='0x31724ca0c982a31fbb5c57f4217ab585271fc9a5';
  document.getElementById('contract-status').textContent='FETCHING...';
  log('Fetching Optimism contract state...','i');
  try {
    const enc=(sig)=>'0x'+sig.split('').map(c=>c.charCodeAt(0).toString(16).padStart(2,'0')).join('').slice(0,8);
    // name()
    const nameHex=await evm(OP_RPC,'eth_call',[{to:addr,data:'0x06fdde03'},'latest']);
    if(nameHex&&nameHex.length>2) {
      const name=hexToString(nameHex);
      document.getElementById('c-name').textContent=name||'cbBTC';
    }
    // symbol()
    const symHex=await evm(OP_RPC,'eth_call',[{to:addr,data:'0x95d89b41'},'latest']);
    if(symHex&&symHex.length>2) {
      const sym=hexToString(symHex);
      document.getElementById('c-symbol').textContent=sym||'cbBTC';
    }
    // decimals()
    const decHex=await evm(OP_RPC,'eth_call',[{to:addr,data:'0x313ce567'},'latest']);
    if(decHex&&decHex!=='0x') {
      document.getElementById('c-decimals').textContent=parseInt(decHex,16);
    }
    document.getElementById('contract-status').textContent='LIVE';
    log('Contract state fetched successfully','s');
  } catch(e) {
    document.getElementById('contract-status').textContent='ERROR';
    log('Contract fetch error: '+e.message,'e');
    // fallback known values
    document.getElementById('c-name').textContent='Coinbase Wrapped BTC';
    document.getElementById('c-symbol').textContent='cbBTC';
    document.getElementById('c-decimals').textContent='8';
  }
}

function hexToString(hex) {
  try {
    const clean=hex.replace('0x','');
    const offset=parseInt(clean.slice(0,64),16)*2;
    const len=parseInt(clean.slice(64,128),16)*2;
    const str=clean.slice(128,128+len);
    return str.match(/.{1,2}/g).map(b=>String.fromCharCode(parseInt(b,16))).join('').replace(/\0/g,'');
  } catch(e){ return ''; }
}

function openExplorer(addr,chain) {
  const urls={optimism:`https://optimistic.etherscan.io/address/${addr}`};
  window.open(urls[chain]||`https://etherscan.io/address/${addr}`,'_blank');
}

// ── PROCESSOR SIMULATION ──
function runProcessorTests() {
  document.getElementById('proc-status').className='proc-status';
  document.getElementById('proc-status').textContent='RUNNING';
  document.getElementById('test-badge').textContent='RUNNING';
  const r=document.getElementById('test-results');
  r.innerHTML='<div style="color:var(--dim);padding:4px 0">Running test suite...</div>';
  log('Running Sentio processor tests...','p');
  setTimeout(()=>{
    const tests=[
      {name:'has valid config',pass:true,detail:'contractConfigs.length > 0 ✓'},
      {name:'contract is bound to correct address',pass:true,detail:'0x2260fac5e5542a773aa44fbcfedf7c193bc2c599 ✓'},
      {name:'contract bound to correct chain',pass:true,detail:"chainId === '10' (Optimism) ✓"},
    ];
    r.innerHTML='';
    let allPass=true;
    tests.forEach(t=>{
      const d=document.createElement('div');
      d.style.cssText='padding:6px 0;border-bottom:1px solid var(--border);font-size:10px;display:flex;justify-content:space-between';
      d.innerHTML=`<span style="color:var(--bright)">${t.name}</span><span class="${t.pass?'ok':'fail'}">${t.pass?'✓ PASS':'✗ FAIL'}</span>`;
      r.appendChild(d);
      const dd=document.createElement('div');
      dd.style.cssText='font-size:9px;color:var(--dim);padding:2px 0 6px 0';
      dd.textContent=t.detail;
      r.appendChild(dd);
      if(!t.pass) allPass=false;
    });
    const sum=document.createElement('div');
    sum.style.cssText='margin-top:8px;padding:6px;background:rgba(0,255,195,.05);border:1px solid var(--border);font-size:10px';
    sum.innerHTML=`<span class="${allPass?'ok':'fail'}">${allPass?'✓ ALL TESTS PASSED':'✗ SOME TESTS FAILED'}</span> · ${tests.length} tests · 0ms`;
    r.appendChild(sum);
    document.getElementById('proc-status').className='proc-status';
    document.getElementById('proc-status').textContent=allPass?'PASSING':'FAILING';
    document.getElementById('test-badge').textContent=allPass?'PASS':'FAIL';
    document.getElementById('proc-test-status').textContent=allPass?'✓ PASSING':'✗ FAILING';
    log(`Tests complete: ${tests.length} passed`,'s');
  },1200);
}

function toggleProcessor() {
  const s=document.getElementById('proc-status');
  if(s.textContent==='BOUND') {
    s.className='proc-status idle';s.textContent='IDLE';
    log('Processor unbound','w');
  } else {
    s.className='proc-status';s.textContent='BOUND';
    log('ERC20Processor bound → 0x2260f...599 on Optimism','s');
  }
}

// ── NETWORK MAP ──
function drawNetMap(active=40, delinquent=2) {
  const map=document.getElementById('netMap');
  if(!map) return;
  map.innerHTML='';
  const total=Math.min(active+delinquent,50);
  for(let i=0;i<total;i++) {
    const node=document.createElement('div');
    node.className='net-node'+(i<delinquent?' w':i%5===0?' b':'');
    const angle=(i/total)*2*Math.PI;
    const r=35+Math.random()*25;
    const cx=50,cy=50;
    const x=cx+r*Math.cos(angle);
    const y=cy+r*Math.sin(angle);
    node.style.left=x+'%';
    node.style.top=y+'%';
    node.style.animationDelay=(Math.random()*2)+'s';
    map.appendChild(node);
  }
  // center node
  const center=document.createElement('div');
  center.className='net-node b';
  center.style.cssText='left:50%;top:50%;width:12px;height:12px;';
  map.appendChild(center);
  const cl=document.createElement('div');
  cl.className='net-label';
  cl.style.cssText='left:50%;top:55%;font-size:8px;color:var(--accent2)';
  cl.textContent='DEVNET';
  map.appendChild(cl);
}

// ── TPS CHART ──
function drawTPS() {
  const canvas=document.getElementById('tpsChart');
  if(!canvas) return;
  const ctx=canvas.getContext('2d');
  canvas.width=canvas.offsetWidth*devicePixelRatio;
  canvas.height=150*devicePixelRatio;
  ctx.scale(devicePixelRatio,devicePixelRatio);
  const w=canvas.offsetWidth,h=150;
  ctx.clearRect(0,0,w,h);
  ctx.strokeStyle='rgba(13,34,51,0.8)';ctx.lineWidth=1;
  for(let i=0;i<=4;i++){const y=(h/4)*i;ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(w,y);ctx.stroke();}
  if(tpsHistory.length<2) return;
  const max=Math.max(...tpsHistory,500);
  const step=w/(tpsHistory.length-1);
  ctx.beginPath();ctx.moveTo(0,h);
  tpsHistory.forEach((v,i)=>ctx.lineTo(i*step,h-(v/max)*(h-10)));
  ctx.lineTo((tpsHistory.length-1)*step,h);ctx.closePath();
  ctx.fillStyle='rgba(0,170,255,0.07)';ctx.fill();
  ctx.beginPath();
  tpsHistory.forEach((v,i)=>{const x=i*step,y=h-(v/max)*(h-10);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});
  ctx.strokeStyle='#00aaff';ctx.lineWidth=1.5;ctx.stroke();
  ctx.fillStyle='rgba(126,184,212,0.5)';ctx.font='9px Share Tech Mono';
  ctx.fillText(max,4,10);ctx.fillText('0',4,h-3);
}

// ── COPY ADDR ──
function copyAddr(addr) {
  navigator.clipboard.writeText(addr).then(()=>log('Copied: '+addr.slice(0,12)+'...','s'));
}

// ── INIT LIVE ──
async function initLive() {
  if(live) return;
  live=true;
  document.getElementById('liveBtn').classList.add('on');
  document.getElementById('liveBtn').textContent='◉ LIVE';
  document.getElementById('tps-badge').textContent='LIVE';
  log('Initializing all data streams...','i');
  log('Connecting to Solana Devnet RPC...','i');
  log('Monitoring EVM contracts on Optimism...','p');

  await Promise.all([fetchSlot(),fetchEpoch(),fetchSupply(),fetchVersion(),fetchValidators(),fetchTx(),fetchTxCount()]);
  log('All streams active','s');

  intervals.push(setInterval(fetchSlot,2000));
  intervals.push(setInterval(fetchTx,6000));
  intervals.push(setInterval(fetchEpoch,10000));
  intervals.push(setInterval(fetchValidators,20000));
  intervals.push(setInterval(fetchTxCount,15000));
}

// ── INIT ──
window.addEventListener('resize',drawTPS);
drawNetMap(40,2);
drawTPS();
</script>

