      "args": ["-y", "@coinbase/cb-mcp"],
      "env": {
        "Charless-iMac.attlocal.net-def077f7": "organizations/60bfedf4-17db-451f-80aa-a7291a690bbd/apiKeys/7b963d75-087b-4f7d-9ba6-c99f4ab2a14e",
