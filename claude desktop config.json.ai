{
  "mcpServers": {

    "mcp-wallet": {
      "command": "node",
      "args": ["/absolute/path/to/mcp-wallet-server/server.js"],
      "env": {
        "RPC_URL": "http://localhost:8545",
        "BITPAY_API_KEY": "YOUR_BITPAY_KEY",
        "COINBASE_API_KEY": "organizations/60bfedf4-17db-451f-80aa-a7291a690bbd/apiKeys/7b963d75-087b-4f7d-9ba6-c99f4ab2a14e",
        "COINBASE_API_SECRET": "-----BEGIN EC PRIVATE KEY-----\nMHcCAQEEICqN9yjJZfpI/1wxFBGDrAdHEO86/Ng9vd05WA4S00JDoAoGCCqGSM49\nAwEHoUQDQgAEGiJdleJeeD3ofg9TOkE+DApVXI5pssURHnQ/4OpXPvj9XKU0PNzs\nGX53Ee8G2Q6ELKEi63SU3+v2F0eRnDq0bw==\n-----END EC PRIVATE KEY-----\n,
        "u1PBnXfqs3TCwuPlJiNHd7QhQL960EfRx": "u1PBnXfqs3TCwuPlJiNHd7QhQL960EfRx",
        "SENTIO_PROJECT_SLUG": "cbWETH"
      }
    },

    "sentio-mcp": {
      "command": "npx",
      "args": ["-y", "@sentio/mcp"],
      "env": {
        "u1PBnXfqs3TCwuPlJiNHd7QhQL960EfRx": "u1PBnXfqs3TCwuPlJiNHd7QhQL960EfRx",
        "charles_henderson34/coinbaseweth": "cbWETH"
      }
    },

    "cb-mcp": {
      "command": "npx",
      "args": ["-y", "@coinbase/cb-mcp"],
      "env": {
        "Charless-iMac.attlocal.net-def077f7": "Charless-iMac.attlocal.net-def077f7,
        "organizations/60bfedf4-17db-451f-80aa-a7291a690bbd/apiKeys/7b963d75-087b-4f7d-9ba6-c99f4ab2a14e": "-----BEGIN EC PRIVATE KEY-----\nMHcCAQEEICqN9yjJZfpI/1wxFBGDrAdHEO86/Ng9vd05WA4S00JDoAoGCCqGSM49\nAwEHoUQDQgAEGiJdleJeeD3ofg9TOkE+DApVXI5pssURHnQ/4OpXPvj9XKU0PNzs\nGX53Ee8G2Q6ELKEi63SU3+v2F0eRnDq0bw==\n-----END EC PRIVATE KEY-----\n"
